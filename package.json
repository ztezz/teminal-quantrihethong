{
  "name": "terminal-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "backend": "tsx server.ts --backend",
    "build": "next build",
    "build:backend": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/server.js",
    "deploy": "npm run build && wrangler deploy",
    "start": "tsx server.ts",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit --incremental false",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "archiver": "^8.0.0",
    "argon2": "^0.44.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^16.2.10",
    "node-pty": "^1.1.0",
    "otplib": "^12.0.1",
    "postcss": "^8.5.19",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.3.1",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/archiver": "^8.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/unzipper": "^0.10.11",
    "esbuild": "^0.28.1",
    "eslint": "9.39.1",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "4.1.11",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "wrangler": "4.110.0"
  }
}
