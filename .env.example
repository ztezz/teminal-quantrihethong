NEXT_PUBLIC_API_URL=https://api-ssh.luugame.fun
TERMINAL_PASSWORD=replace-with-a-strong-password
TERMINAL_MAX_SESSIONS_PER_USER=3
TERMINAL_IDLE_TIMEOUT_MINUTES=30
TERMINAL_MAX_LIFETIME_MINUTES=480
# Optional UTF-8 locale for interactive terminal applications (for example C.UTF-8).
TERMINAL_LANG=C.UTF-8
BACKEND_PORT=3001
FRONTEND_ORIGIN=https://ssh.luugame.fun
# Set to 1 only when exactly one trusted reverse proxy is in front of the backend.
TRUST_PROXY=
DATABASE_PATH=terminal_database.sqlite
LEGACY_DATABASE_PATH=terminal_database.json
FILE_MANAGER_ROOT=.
FILE_MANAGER_TRASH_DIR=.terminal-trash
FILE_MANAGER_SNAPSHOT_DIR=.terminal-snapshots
SNAPSHOT_MAX_FILE_MB=100
SNAPSHOT_MAX_TOTAL_MB=2048
# Maximum total size of one chunked upload. Each HTTP request is at most 8 MiB.
UPLOAD_MAX_FILE_MB=10240
LIBREOFFICE_PATH=libreoffice
OFFICE_MAX_CONCURRENCY=1
AUTH_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
AUDIT_RETENTION_DAYS=90
AUDIT_MAX_ENTRIES=100000
# Optional HMAC key for audit hashes. Once enabled, keep this secret stable.
AUDIT_HMAC_KEY=
TOTP_ISSUER=Terminal Admin
# Background jobs and scheduled SQLite backups
JOB_DATA_DIR=.terminal-jobs
JOB_HISTORY_LIMIT=200
SQLITE_MANAGER_ROOT=.
SQLITE_BROWSER_ROOT=/
SQLITE_BACKUP_DIR=.terminal-sqlite-backups
SQLITE_BACKUP_SCHEDULE_MINUTES=0
SQLITE_SCHEDULED_DATABASES=terminal_database.sqlite
SQLITE_BACKUP_RETENTION_COUNT=10
# Failure alerts require HTTPS. In production ALERT_WEBHOOK_HOSTS is mandatory.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_HOSTS=
