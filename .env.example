# URL backend API (Express + Socket.io server)
# Khi deploy frontend lên Cloudflare Pages, đặt đây là địa chỉ backend VPS
# Để trống nếu chạy full-stack cùng server (npm run dev)
NEXT_PUBLIC_API_URL=https://api-ssh.luugame.fun

# Password for terminal login. Defaults to admin
TERMINAL_PASSWORD=admin

# (Backend only) Port cho server.ts --backend
BACKEND_PORT=3001

# (Backend only) CORS origin được phép gọi API
FRONTEND_ORIGIN=https://your-site.pages.dev

# Thư mục gốc mà File Manager được phép quản lý.
# Khi chạy bằng user không phải root, đặt thành một thư mục/volume có quyền ghi.
# Ví dụ: /app/data
FILE_MANAGER_ROOT=
