NEXT_PUBLIC_API_URL=
TERMINAL_PASSWORD=replace-with-a-strong-password
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
# Set to 1 only when exactly one trusted reverse proxy is in front of the backend.
TRUST_PROXY=
FILE_MANAGER_ROOT=.
FILE_MANAGER_TRASH_DIR=.terminal-trash
FILE_MANAGER_SNAPSHOT_DIR=.terminal-snapshots
SNAPSHOT_MAX_FILE_MB=100
SNAPSHOT_MAX_TOTAL_MB=2048
LIBREOFFICE_PATH=libreoffice
OFFICE_MAX_CONCURRENCY=1
AUTH_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
TOTP_ISSUER=Terminal Admin
